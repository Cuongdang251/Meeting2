# =====================================================================
# CẤU HÌNH KẾT NỐI SQL SERVER (SSMS) - sao chép file này thành ".env"
# =====================================================================

# Driver ODBC đã cài trên máy (xem README để cài đặt)
SQL_DRIVER={ODBC Driver 18 for SQL Server}

# Tên server / instance SQL Server, ví dụ:
#   - "localhost" hoặc "localhost\\SQLEXPRESS"
#   - "DESKTOP-ABC123\\SQLEXPRESS"
#   - "192.168.1.10,1433"
SQL_SERVER=localhost

SQL_DATABASE=xyz_meeting_room

# "sql"     -> đăng nhập bằng SQL Server Authentication (SQL_USERNAME/SQL_PASSWORD)
# "windows" -> đăng nhập bằng Windows Authentication (không cần user/pass)
SQL_AUTH_MODE=sql
SQL_USERNAME=sa
SQL_PASSWORD=YourStrong@Passw0rd

# Bật/tắt mã hóa kết nối - để "yes" theo mặc định của Driver 18
SQL_ENCRYPT=yes
SQL_TRUST_SERVER_CERTIFICATE=yes

# Cấu hình Flask
PORT=3000
FLASK_DEBUG=true
# Khóa bí mật ký session đăng nhập - BẮT BUỘC đổi giá trị này khi triển khai thật
SECRET_KEY=doi-chuoi-bi-mat-nay-truoc-khi-trien-khai-that

# Số lượng mã phòng gợi ý PH001..PH0xx cho dropdown "Mã phòng họp"
ROOM_CODE_POOL_SIZE=20
